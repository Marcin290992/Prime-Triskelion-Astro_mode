---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Prime Triskelion – a creative digital agency delivering exceptional web experiences.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Prime Triskelion</title>
  </head>
  <body>
    <!-- Page transition overlay -->
    <div class="transition-overlay" id="transition-overlay"></div>

    <!-- Navigation -->
    <header
      class="fixed top-0 left-0 right-0 z-50 px-6 py-5 flex items-center justify-between"
      id="navbar"
    >
      <a href="/" class="flex items-center gap-3 group" aria-label="Prime Triskelion home">
        <!-- Triskelion SVG logo -->
        <svg
          width="40"
          height="40"
          viewBox="0 0 100 100"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="text-brand-400 group-hover:text-brand-300 transition-colors"
          aria-hidden="true"
        >
          <circle cx="50" cy="50" r="48" stroke="currentColor" stroke-width="2" opacity="0.3"/>
          <path d="M50 50 L50 10 A40 40 0 0 1 84.64 30 Z" fill="currentColor" opacity="0.9"/>
          <path d="M50 50 L84.64 30 A40 40 0 0 1 84.64 70 Z" fill="currentColor" opacity="0.7"/>
          <path d="M50 50 L84.64 70 A40 40 0 0 1 15.36 70 Z" fill="currentColor" opacity="0.5"/>
          <circle cx="50" cy="50" r="6" fill="currentColor"/>
        </svg>
        <span class="font-display font-bold text-xl text-white">Prime Triskelion</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        <a href="/" class="nav-link text-white/70 hover:text-white transition-colors text-sm font-medium" data-barba-prevent="self">Home</a>
        <a href="/services" class="nav-link text-white/70 hover:text-white transition-colors text-sm font-medium" data-barba-prevent="self">Services</a>
        <a href="/about" class="nav-link text-white/70 hover:text-white transition-colors text-sm font-medium" data-barba-prevent="self">About</a>
        <a href="/contact" class="nav-link text-white/70 hover:text-white transition-colors text-sm font-medium" data-barba-prevent="self">Contact</a>
        <a href="/contact" class="btn-primary text-sm py-3 px-6" data-barba-prevent="self">Get Started</a>
      </nav>

      <!-- Hamburger (mobile) -->
      <button
        id="menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2 text-white"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="block w-6 h-0.5 bg-current transition-all duration-300" id="ham-top"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-300" id="ham-mid"></span>
        <span class="block w-4 h-0.5 bg-current transition-all duration-300" id="ham-bot"></span>
      </button>
    </header>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="fixed inset-0 z-40 bg-dark-900/95 backdrop-blur-xl flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-all duration-300"
      aria-hidden="true"
    >
      <a href="/" class="font-display text-3xl font-bold text-white hover:text-brand-400 transition-colors" data-barba-prevent="self">Home</a>
      <a href="/services" class="font-display text-3xl font-bold text-white hover:text-brand-400 transition-colors" data-barba-prevent="self">Services</a>
      <a href="/about" class="font-display text-3xl font-bold text-white hover:text-brand-400 transition-colors" data-barba-prevent="self">About</a>
      <a href="/contact" class="font-display text-3xl font-bold text-white hover:text-brand-400 transition-colors" data-barba-prevent="self">Contact</a>
    </div>

    <!-- Barba wrapper / main content -->
    <div data-barba="wrapper">
      <main data-barba="container" data-barba-namespace="page">
        <slot />
      </main>
    </div>

    <!-- Footer -->
    <footer class="border-t border-white/5 bg-dark-800">
      <div class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
          <!-- Brand -->
          <div class="md:col-span-2">
            <a href="/" class="flex items-center gap-3 mb-6 group" aria-label="Prime Triskelion">
              <svg width="36" height="36" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-brand-400" aria-hidden="true">
                <circle cx="50" cy="50" r="48" stroke="currentColor" stroke-width="2" opacity="0.3"/>
                <path d="M50 50 L50 10 A40 40 0 0 1 84.64 30 Z" fill="currentColor" opacity="0.9"/>
                <path d="M50 50 L84.64 30 A40 40 0 0 1 84.64 70 Z" fill="currentColor" opacity="0.7"/>
                <path d="M50 50 L84.64 70 A40 40 0 0 1 15.36 70 Z" fill="currentColor" opacity="0.5"/>
                <circle cx="50" cy="50" r="6" fill="currentColor"/>
              </svg>
              <span class="font-display font-bold text-lg text-white">Prime Triskelion</span>
            </a>
            <p class="text-white/50 text-sm leading-relaxed max-w-xs">
              We craft digital experiences that move people. Strategy, design, and technology — unified.
            </p>
          </div>

          <!-- Links -->
          <div>
            <h3 class="font-semibold text-white mb-4">Pages</h3>
            <ul class="space-y-3">
              <li><a href="/" class="text-white/50 hover:text-white text-sm transition-colors">Home</a></li>
              <li><a href="/services" class="text-white/50 hover:text-white text-sm transition-colors">Services</a></li>
              <li><a href="/about" class="text-white/50 hover:text-white text-sm transition-colors">About</a></li>
              <li><a href="/contact" class="text-white/50 hover:text-white text-sm transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h3 class="font-semibold text-white mb-4">Contact</h3>
            <ul class="space-y-3">
              <li><a href="mailto:hello@primetriskelion.com" class="text-white/50 hover:text-white text-sm transition-colors">hello@primetriskelion.com</a></li>
              <li><span class="text-white/50 text-sm">Warsaw, Poland</span></li>
            </ul>
          </div>
        </div>

        <div class="mt-12 pt-6 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-white/30 text-sm">&copy; {new Date().getFullYear()} Prime Triskelion. All rights reserved.</p>
          <p class="text-white/30 text-sm">Built with Astro · GSAP · Barba.js</p>
        </div>
      </div>
    </footer>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import barba from '@barba/core';

      gsap.registerPlugin(ScrollTrigger);

      /* ─── Navbar scroll effect ─── */
      const navbar = document.getElementById('navbar');
      window.addEventListener('scroll', () => {
        if (navbar) {
          if (window.scrollY > 20) {
            navbar.classList.add('bg-dark-900/90', 'backdrop-blur-xl', 'border-b', 'border-white/5');
          } else {
            navbar.classList.remove('bg-dark-900/90', 'backdrop-blur-xl', 'border-b', 'border-white/5');
          }
        }
      });

      /* ─── Mobile menu ─── */
      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamTop = document.getElementById('ham-top');
      const hamMid = document.getElementById('ham-mid');
      const hamBot = document.getElementById('ham-bot');

      let menuOpen = false;
      menuBtn?.addEventListener('click', () => {
        menuOpen = !menuOpen;
        menuBtn.setAttribute('aria-expanded', String(menuOpen));
        mobileMenu?.setAttribute('aria-hidden', String(!menuOpen));

        if (menuOpen) {
          mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
          mobileMenu?.classList.add('opacity-100', 'pointer-events-auto');
          hamMid?.classList.add('opacity-0');
          hamTop?.classList.add('rotate-45', 'translate-y-2');
          hamBot?.classList.add('-rotate-45', '-translate-y-2', 'w-6');
        } else {
          mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
          mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
          hamMid?.classList.remove('opacity-0');
          hamTop?.classList.remove('rotate-45', 'translate-y-2');
          hamBot?.classList.remove('-rotate-45', '-translate-y-2', 'w-6');
        }
      });

      // Close mobile menu when a link is clicked
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          menuOpen = false;
          menuBtn?.setAttribute('aria-expanded', 'false');
          mobileMenu.classList.add('opacity-0', 'pointer-events-none');
          mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        });
      });

      /* ─── GSAP scroll animations ─── */
      function initScrollAnimations() {
        // Fade-up elements
        gsap.utils.toArray<HTMLElement>('[data-gsap="fade-up"]').forEach((el) => {
          gsap.fromTo(el,
            { opacity: 0, y: 40 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Stagger children
        gsap.utils.toArray<HTMLElement>('[data-gsap="stagger"]').forEach((container) => {
          const children = container.children;
          gsap.fromTo(children,
            { opacity: 0, y: 30 },
            {
              opacity: 1,
              y: 0,
              duration: 0.7,
              ease: 'power3.out',
              stagger: 0.12,
              scrollTrigger: {
                trigger: container,
                start: 'top 80%',
                once: true,
              },
            }
          );
        });
      }

      /* ─── Barba.js page transitions ─── */
      const overlay = document.getElementById('transition-overlay');

      function leaveAnimation() {
        return gsap.to(overlay, {
          y: '0%',
          duration: 0.5,
          ease: 'power3.inOut',
        });
      }

      function enterAnimation() {
        return gsap.to(overlay, {
          y: '100%',
          duration: 0.5,
          ease: 'power3.inOut',
          onComplete: () => {
            gsap.set(overlay, { y: '-100%' });
          },
        });
      }

      barba.init({
        transitions: [
          {
            name: 'slide-transition',
            async leave() {
              await leaveAnimation();
            },
            async enter() {
              window.scrollTo(0, 0);
              ScrollTrigger.refresh();
              initScrollAnimations();
              await enterAnimation();
            },
          },
        ],
        views: [
          {
            namespace: 'page',
            afterEnter() {
              initScrollAnimations();
            },
          },
        ],
      });

      // Initial load animations
      initScrollAnimations();
    </script>
  </body>
</html>
