---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Prime Triskelion – Creative digital agency building exceptional web experiences.">

  <!-- ─── Hero ─── -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-dark-900">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 -left-32 w-96 h-96 bg-brand-600/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-brand-400/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-500/5 rounded-full blur-3xl"></div>
    </div>

    <!-- Grid overlay -->
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxwYXRoIGQ9Ik0wIDYwTDYwIDAiIHN0cm9rZT0iI2ZmZiIgc3Ryb2tlLW9wYWNpdHk9Ii4wMyIvPjwvZz48L3N2Zz4=')] opacity-60" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-24 text-center">
      <div id="hero-label" class="opacity-0">
        <span class="section-label">Creative Digital Agency</span>
      </div>

      <h1
        id="hero-title"
        class="font-display text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.05] mb-8 opacity-0"
      >
        We Build&nbsp;<span class="text-brand-400">Digital</span><br/>
        Experiences&nbsp;<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-200">That Matter</span>
      </h1>

      <p
        id="hero-sub"
        class="text-white/60 text-lg md:text-xl max-w-2xl mx-auto mb-12 opacity-0"
      >
        Strategy, design, and cutting-edge technology — we craft websites and apps
        that drive real growth for ambitious brands.
      </p>

      <div id="hero-cta" class="flex flex-col sm:flex-row gap-4 justify-center opacity-0">
        <a href="/services" class="btn-primary">Explore Services</a>
        <a href="/about" class="btn-outline">Meet the Team</a>
      </div>

      <!-- Scroll indicator -->
      <div id="scroll-indicator" class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0">
        <span class="text-white/30 text-xs tracking-widest uppercase">Scroll</span>
        <div class="w-px h-12 bg-gradient-to-b from-white/30 to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- ─── Stats ─── -->
  <section class="py-20 bg-dark-800 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-gsap="stagger">
        <div>
          <p class="font-display text-5xl font-bold text-brand-400 mb-2">50+</p>
          <p class="text-white/50 text-sm">Projects Delivered</p>
        </div>
        <div>
          <p class="font-display text-5xl font-bold text-brand-400 mb-2">8+</p>
          <p class="text-white/50 text-sm">Years of Experience</p>
        </div>
        <div>
          <p class="font-display text-5xl font-bold text-brand-400 mb-2">35+</p>
          <p class="text-white/50 text-sm">Happy Clients</p>
        </div>
        <div>
          <p class="font-display text-5xl font-bold text-brand-400 mb-2">99%</p>
          <p class="text-white/50 text-sm">Client Satisfaction</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Services Preview ─── -->
  <section class="py-28 bg-dark-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16" data-gsap="fade-up">
        <span class="section-label">What We Do</span>
        <h2 class="section-title">Services Built for <br/><span class="text-brand-400">Modern Brands</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-gsap="stagger">
        <!-- Web Design -->
        <div class="card group">
          <div class="w-14 h-14 rounded-xl bg-brand-500/10 flex items-center justify-center mb-6 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-7 h-7 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold mb-3">Web Design</h3>
          <p class="text-white/50 text-sm leading-relaxed">Pixel-perfect interfaces crafted with purpose — beautiful, accessible, and conversion-focused.</p>
        </div>

        <!-- Development -->
        <div class="card group">
          <div class="w-14 h-14 rounded-xl bg-brand-500/10 flex items-center justify-center mb-6 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-7 h-7 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold mb-3">Web Development</h3>
          <p class="text-white/50 text-sm leading-relaxed">High-performance websites and web apps built with Astro, React, and modern tooling.</p>
        </div>

        <!-- Branding -->
        <div class="card group">
          <div class="w-14 h-14 rounded-xl bg-brand-500/10 flex items-center justify-center mb-6 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-7 h-7 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold mb-3">Brand Identity</h3>
          <p class="text-white/50 text-sm leading-relaxed">Cohesive visual identities that communicate your values and differentiate you from the crowd.</p>
        </div>
      </div>

      <div class="text-center mt-12" data-gsap="fade-up">
        <a href="/services" class="btn-outline">View All Services</a>
      </div>
    </div>
  </section>

  <!-- ─── Process ─── -->
  <section class="py-28 bg-dark-800">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16" data-gsap="fade-up">
        <span class="section-label">How We Work</span>
        <h2 class="section-title">Our <span class="text-brand-400">Process</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6" data-gsap="stagger">
        {[
          { step: '01', title: 'Discover', desc: 'Deep-dive into your goals, audience, and competitive landscape.' },
          { step: '02', title: 'Strategise', desc: 'Define a clear roadmap, architecture, and success metrics.' },
          { step: '03', title: 'Design & Build', desc: 'Iterate rapidly with prototypes, then ship polished production code.' },
          { step: '04', title: 'Grow', desc: 'Optimise, analyse, and continuously improve post-launch.' },
        ].map(({ step, title, desc }) => (
          <div class="relative card text-center">
            <span class="font-display text-6xl font-bold text-brand-500/20 absolute -top-4 left-1/2 -translate-x-1/2">{step}</span>
            <h3 class="font-display text-xl font-bold mt-8 mb-3">{title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="py-28 bg-dark-900 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-px bg-gradient-to-r from-transparent via-brand-500/40 to-transparent"></div>
    </div>
    <div class="max-w-3xl mx-auto px-6 text-center" data-gsap="fade-up">
      <span class="section-label">Ready to Start?</span>
      <h2 class="section-title mb-6">Let's Build Something <span class="text-brand-400">Amazing</span></h2>
      <p class="text-white/50 text-lg mb-10">Tell us about your project and we'll get back to you within 24 hours.</p>
      <a href="/contact" class="btn-primary">Start a Project</a>
    </div>
  </section>

</Layout>

<script>
  import gsap from 'gsap';

  // Hero entrance animation (runs on first load)
  const tl = gsap.timeline({ delay: 0.2 });
  tl.to('#hero-label',    { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
    .to('#hero-title',    { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3')
    .to('#hero-sub',      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.4')
    .to('#hero-cta',      { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.3')
    .to('#scroll-indicator', { opacity: 1, duration: 0.5 }, '-=0.1');
</script>
