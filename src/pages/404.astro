---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 – Page Not Found">
  <section class="min-h-screen flex items-center justify-center bg-dark-900 text-center px-6">
    <div data-gsap="fade-up">
      <span class="section-label">Error 404</span>
      <h1 class="font-display text-8xl md:text-9xl font-bold text-brand-500/20 mb-4">404</h1>
      <h2 class="section-title mb-6">Page Not <span class="text-brand-400">Found</span></h2>
      <p class="text-white/50 text-lg mb-10 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="btn-primary">Back to Home</a>
    </div>
  </section>
</Layout>
