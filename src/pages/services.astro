---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
    title: 'Web Design',
    description: 'Pixel-perfect interfaces crafted with purpose. We design experiences that are beautiful, accessible, and optimised for conversions — from landing pages to complex dashboards.',
    features: ['UI/UX Research', 'Wireframing & Prototyping', 'Responsive Design', 'Design Systems'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>`,
    title: 'Web Development',
    description: 'High-performance websites and web applications built with modern tooling. We specialise in Astro, React, and TypeScript for blazing-fast, SEO-friendly products.',
    features: ['Astro & React', 'CMS Integration', 'API Development', 'Performance Optimisation'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>`,
    title: 'Brand Identity',
    description: 'Cohesive visual identities that communicate your values, build trust, and differentiate you from the competition — from logo to full brand guidelines.',
    features: ['Logo Design', 'Brand Guidelines', 'Typography & Colour', 'Brand Strategy'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    title: 'Motion & Animation',
    description: 'Bring your brand to life with GSAP-powered animations, micro-interactions, and seamless page transitions that delight users and reinforce your story.',
    features: ['GSAP Animations', 'Page Transitions', 'Micro-interactions', 'Lottie Integration'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
    title: 'SEO & Performance',
    description: 'Rank higher and load faster. Our technical SEO and Core Web Vitals expertise ensures your site gets found and your visitors stay.',
    features: ['Technical SEO Audit', 'Core Web Vitals', 'Content Strategy', 'Analytics Setup'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>`,
    title: 'Mobile-First Apps',
    description: 'Progressive Web Apps and responsive experiences that work flawlessly on every device — from a 320px phone to a 4K monitor.',
    features: ['PWA Development', 'Responsive UX', 'Offline Support', 'App-like Experiences'],
  },
];
---

<Layout title="Services" description="Explore Prime Triskelion's full range of digital services — from web design and development to branding and animation.">

  <!-- Hero -->
  <section class="relative pt-40 pb-20 bg-dark-900 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-brand-600/10 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-4xl mx-auto px-6 text-center" data-gsap="fade-up">
      <span class="section-label">What We Offer</span>
      <h1 class="section-title mb-6">Services That <span class="text-brand-400">Drive Results</span></h1>
      <p class="text-white/50 text-lg max-w-2xl mx-auto">
        From concept to launch, we offer end-to-end digital solutions tailored to your goals.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-dark-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-gsap="stagger">
        {services.map(({ icon, title, description, features }) => (
          <div class="card flex flex-col gap-6">
            <div class="w-14 h-14 rounded-xl bg-brand-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" set:html={icon}></svg>
            </div>
            <div>
              <h2 class="font-display text-xl font-bold mb-3">{title}</h2>
              <p class="text-white/50 text-sm leading-relaxed mb-5">{description}</p>
              <ul class="space-y-2">
                {features.map(f => (
                  <li class="flex items-center gap-2 text-sm text-white/70">
                    <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 bg-dark-800">
    <div class="max-w-3xl mx-auto px-6 text-center" data-gsap="fade-up">
      <span class="section-label">Ready to Begin?</span>
      <h2 class="section-title mb-6">Have a Project in <span class="text-brand-400">Mind?</span></h2>
      <p class="text-white/50 text-lg mb-10">Let's talk about how we can help you achieve your goals.</p>
      <a href="/contact" class="btn-primary">Get in Touch</a>
    </div>
  </section>

</Layout>
