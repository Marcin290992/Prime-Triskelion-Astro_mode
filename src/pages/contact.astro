---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Prime Triskelion. Tell us about your project and we'll respond within 24 hours.">

  <!-- Hero -->
  <section class="relative pt-40 pb-20 bg-dark-900 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-brand-600/10 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-4xl mx-auto px-6 text-center" data-gsap="fade-up">
      <span class="section-label">Get in Touch</span>
      <h1 class="section-title mb-6">Let's Talk About <span class="text-brand-400">Your Project</span></h1>
      <p class="text-white/50 text-lg max-w-xl mx-auto">
        Fill in the form below or email us directly. We respond to every inquiry within 24 hours.
      </p>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-20 bg-dark-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Contact info -->
        <div class="lg:col-span-2 space-y-8" data-gsap="fade-up">
          <div>
            <h2 class="font-display text-2xl font-bold mb-6">Contact Details</h2>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-white/40 text-xs font-semibold tracking-widest uppercase mb-1">Email</p>
                  <a href="mailto:hello@primetriskelion.com" class="text-white hover:text-brand-400 transition-colors">hello@primetriskelion.com</a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-white/40 text-xs font-semibold tracking-widest uppercase mb-1">Location</p>
                  <p class="text-white">Warsaw, Poland</p>
                  <p class="text-white/50 text-sm">Available for remote projects worldwide</p>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-white/40 text-xs font-semibold tracking-widest uppercase mb-1">Response Time</p>
                  <p class="text-white">Within 24 hours</p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Social links -->
          <div>
            <p class="text-white/40 text-xs font-semibold tracking-widest uppercase mb-4">Follow Us</p>
            <div class="flex gap-3">
              {[
                { label: 'LinkedIn', href: '#', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
                { label: 'GitHub', href: '#', path: 'M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z' },
              ].map(({ label, href, path }) => (
                <a
                  href={href}
                  class="w-10 h-10 rounded-xl bg-dark-700 hover:bg-brand-500/20 border border-white/5 hover:border-brand-500/30 flex items-center justify-center transition-all duration-200"
                  aria-label={label}
                >
                  <svg class="w-4 h-4 text-white/60 hover:text-brand-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d={path}/>
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3" data-gsap="fade-up">
          <form id="contact-form" class="bg-dark-800 border border-white/5 rounded-2xl p-8 space-y-6" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-white/70 mb-2">Name <span class="text-brand-400">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Your full name"
                  class="w-full bg-dark-700 border border-white/10 focus:border-brand-500 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm outline-none transition-colors"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-white/70 mb-2">Email <span class="text-brand-400">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="you@example.com"
                  class="w-full bg-dark-700 border border-white/10 focus:border-brand-500 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm outline-none transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-white/70 mb-2">Subject</label>
              <select
                id="subject"
                name="subject"
                class="w-full bg-dark-700 border border-white/10 focus:border-brand-500 rounded-xl px-4 py-3 text-white text-sm outline-none transition-colors appearance-none"
              >
                <option value="">Select a topic…</option>
                <option value="web-design">Web Design</option>
                <option value="web-development">Web Development</option>
                <option value="brand-identity">Brand Identity</option>
                <option value="motion">Motion & Animation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="budget" class="block text-sm font-medium text-white/70 mb-2">Estimated Budget</label>
              <select
                id="budget"
                name="budget"
                class="w-full bg-dark-700 border border-white/10 focus:border-brand-500 rounded-xl px-4 py-3 text-white text-sm outline-none transition-colors appearance-none"
              >
                <option value="">Select a range…</option>
                <option value="<5k">Under €5,000</option>
                <option value="5-15k">€5,000 – €15,000</option>
                <option value="15-30k">€15,000 – €30,000</option>
                <option value="30k+">€30,000+</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-white/70 mb-2">Message <span class="text-brand-400">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell us about your project…"
                class="w-full bg-dark-700 border border-white/10 focus:border-brand-500 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm outline-none transition-colors resize-none"
              ></textarea>
            </div>

            <!-- Status messages -->
            <div id="form-success" class="hidden rounded-xl bg-green-500/10 border border-green-500/30 text-green-400 px-4 py-3 text-sm" role="alert">
              ✓ Thank you! We'll be in touch within 24 hours.
            </div>
            <div id="form-error" class="hidden rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 text-sm" role="alert">
              ✕ Please fill in all required fields.
            </div>

            <button type="submit" class="btn-primary w-full justify-center" id="submit-btn">
              Send Message
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name = (form.querySelector('#name') as HTMLInputElement).value.trim();
    const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

    // Hide previous messages
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    if (!name || !email || !message) {
      errorMsg?.classList.remove('hidden');
      return;
    }

    // Simulate form submission (replace with real API call)
    if (submitBtn) {
      const textNode = submitBtn.childNodes[0];
      if (textNode && textNode.nodeType === Node.TEXT_NODE) {
        textNode.textContent = 'Sending… ';
      }
      submitBtn.setAttribute('disabled', 'true');
      submitBtn.setAttribute('aria-busy', 'true');
    }

    setTimeout(() => {
      successMsg?.classList.remove('hidden');
      form.reset();
      if (submitBtn) {
        const textNode = submitBtn.childNodes[0];
        if (textNode && textNode.nodeType === Node.TEXT_NODE) {
          textNode.textContent = 'Send Message ';
        }
        submitBtn.removeAttribute('disabled');
        submitBtn.removeAttribute('aria-busy');
      }
    }, 1000);
  });
</script>
